# Local defaults for deploy_breedos.sh
#
# Copy this file to `.env` next to deploy_breedos.sh and fill in your
# values. The `.env` file is gitignored — each operator keeps their own.
#
#   cp .env.example .env
#   $EDITOR .env

# Remote target for `scp` in the form user@host:/absolute/path/to/engine/
# The trailing slash is required — the script appends `<binary>.UPDATE`.
BREEDOS_DEPLOY_TARGET=user@host:/absolute/path/to/engine/

# Optional: name of the binary on the remote host. Default: breedos
# BREEDOS_BINARY=breedos
